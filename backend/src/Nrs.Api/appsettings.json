{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      // The Camunda job worker long-polls /v2/jobs/activation continuously; the default
      // HttpClient request logging would flood the logs with idle poll traffic. Quiet it.
      "System.Net.Http.HttpClient.ICamundaClient": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Enabled": false,
    "Authority": "http://localhost:8081/realms/nrs",
    "Audience": "nrs-api"
  },
  "Database": {
    // Apply EF Core migrations on startup. The demo stacks rely on this; a controlled
    // production rollout may set it false and run migrations as a separate, deliberate step.
    "InitializeOnStartup": true
    // SeedOnStartup (synthetic Bogus demo data) is intentionally NOT set here: it defaults
    // to true OUTSIDE Production and false IN Production (see Program.cs), so a real registry
    // is never auto-filled with fakes. Demo stacks opt in via the env var
    // Database__SeedOnStartup=true (see docker-compose.yml).
  }
}
