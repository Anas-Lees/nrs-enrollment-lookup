<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_EnrollmentReview"
                  targetNamespace="http://nrs.rop.gov.om/enrollment">

  <!--
    Enrollment review, version 2 — the human-in-the-loop shape:

      submit -> automated screening -> clean renewal?  yes -> auto-approve (straight-through)
                                                       no  -> reviewer USER TASK (claim/decide)
                                                              · escalation timer -> notify supervisor
                                                       -> apply approved / rejected

    Camunda drives the flow; the API's workers own the side effects (Oracle status
    writes + notifications). The reviewer step is a real Camunda user task, so it is
    visible both in the app's Review Tasks screen and in Camunda Tasklist.
  -->
  <bpmn:process id="enrollment-review" name="Enrollment review" isExecutable="true">

    <bpmn:startEvent id="StartEvent_1" name="Submitted">
      <bpmn:outgoing>Flow_Start_Screen</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Automated screening: registry CRN check, duplicate check, clean-renewal detection. -->
    <bpmn:serviceTask id="Activity_Screen" name="Screen application">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="screen-application" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_Screen</bpmn:incoming>
      <bpmn:outgoing>Flow_Screen_Gw</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_Auto" name="Clean renewal?" default="Flow_Gw_Review">
      <bpmn:incoming>Flow_Screen_Gw</bpmn:incoming>
      <bpmn:outgoing>Flow_Gw_Auto</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gw_Review</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Straight-through processing: a clean renewal is approved without a human. -->
    <bpmn:serviceTask id="Activity_AutoApprove" name="Auto-approve">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="apply-approved" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gw_Auto</bpmn:incoming>
      <bpmn:outgoing>Flow_Auto_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="Event_AutoApproved" name="Auto-approved">
      <bpmn:incoming>Flow_Auto_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:serviceTask id="Activity_MarkReview" name="Queue for review">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="queue-for-review" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gw_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Mark_Notify</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_NotifyReviewers" name="Notify reviewers">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:taskHeaders>
          <zeebe:header key="kind" value="review-queued" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Mark_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_Review</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- The human decision: a Camunda user task offered to the reviewer group. -->
    <bpmn:userTask id="Activity_Review" name="Review application">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="reviewer" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Notify_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_Gw</bpmn:outgoing>
    </bpmn:userTask>

    <!-- SLA escalation: if the review sits unactioned, tell a supervisor (non-interrupting:
         the review itself stays open). Duration comes from the escalationAfter variable. -->
    <bpmn:boundaryEvent id="Event_EscalationTimer" name="Review overdue" cancelActivity="false" attachedToRef="Activity_Review">
      <bpmn:outgoing>Flow_Timer_Escalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Escalation">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=escalationAfter</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Activity_NotifySupervisor" name="Notify supervisor">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:taskHeaders>
          <zeebe:header key="kind" value="escalated" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Timer_Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_Escalate_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="Event_Escalated" name="Escalation sent">
      <bpmn:incoming>Flow_Escalate_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_Approved" name="Approved?" default="Flow_Gw_Reject">
      <bpmn:incoming>Flow_Review_Gw</bpmn:incoming>
      <bpmn:outgoing>Flow_Gw_Approve</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gw_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Activity_Approve" name="Approve application">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="apply-approved" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gw_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_Approve_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_Reject" name="Reject application">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="apply-rejected" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gw_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="Event_Approved" name="Approved">
      <bpmn:incoming>Flow_Approve_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="Event_Rejected" name="Rejected">
      <bpmn:incoming>Flow_Reject_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_Screen" sourceRef="StartEvent_1" targetRef="Activity_Screen" />
    <bpmn:sequenceFlow id="Flow_Screen_Gw" sourceRef="Activity_Screen" targetRef="Gateway_Auto" />
    <bpmn:sequenceFlow id="Flow_Gw_Auto" name="yes" sourceRef="Gateway_Auto" targetRef="Activity_AutoApprove">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=autoApprove = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gw_Review" name="no" sourceRef="Gateway_Auto" targetRef="Activity_MarkReview" />
    <bpmn:sequenceFlow id="Flow_Auto_End" sourceRef="Activity_AutoApprove" targetRef="Event_AutoApproved" />
    <bpmn:sequenceFlow id="Flow_Mark_Notify" sourceRef="Activity_MarkReview" targetRef="Activity_NotifyReviewers" />
    <bpmn:sequenceFlow id="Flow_Notify_Review" sourceRef="Activity_NotifyReviewers" targetRef="Activity_Review" />
    <bpmn:sequenceFlow id="Flow_Review_Gw" sourceRef="Activity_Review" targetRef="Gateway_Approved" />
    <bpmn:sequenceFlow id="Flow_Timer_Escalate" sourceRef="Event_EscalationTimer" targetRef="Activity_NotifySupervisor" />
    <bpmn:sequenceFlow id="Flow_Escalate_End" sourceRef="Activity_NotifySupervisor" targetRef="Event_Escalated" />
    <bpmn:sequenceFlow id="Flow_Gw_Approve" name="yes" sourceRef="Gateway_Approved" targetRef="Activity_Approve">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=approved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gw_Reject" name="no" sourceRef="Gateway_Approved" targetRef="Activity_Reject" />
    <bpmn:sequenceFlow id="Flow_Approve_End" sourceRef="Activity_Approve" targetRef="Event_Approved" />
    <bpmn:sequenceFlow id="Flow_Reject_End" sourceRef="Activity_Reject" targetRef="Event_Rejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="enrollment-review">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="146" y="265" width="49" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Screen_di" bpmnElement="Activity_Screen">
        <dc:Bounds x="240" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Auto_di" bpmnElement="Gateway_Auto" isMarkerVisible="true">
        <dc:Bounds x="395" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="381" y="272" width="79" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AutoApprove_di" bpmnElement="Activity_AutoApprove">
        <dc:Bounds x="500" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_AutoApproved_di" bpmnElement="Event_AutoApproved">
        <dc:Bounds x="662" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="643" y="125" width="75" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_MarkReview_di" bpmnElement="Activity_MarkReview">
        <dc:Bounds x="500" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_NotifyReviewers_di" bpmnElement="Activity_NotifyReviewers">
        <dc:Bounds x="650" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Review_di" bpmnElement="Activity_Review">
        <dc:Bounds x="800" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_EscalationTimer_di" bpmnElement="Event_EscalationTimer">
        <dc:Bounds x="832" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="761" y="273" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_NotifySupervisor_di" bpmnElement="Activity_NotifySupervisor">
        <dc:Bounds x="800" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Escalated_di" bpmnElement="Event_Escalated">
        <dc:Bounds x="962" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="941" y="425" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Approved_di" bpmnElement="Gateway_Approved" isMarkerVisible="true">
        <dc:Bounds x="955" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="952" y="191" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Approve_di" bpmnElement="Activity_Approve">
        <dc:Bounds x="1060" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Reject_di" bpmnElement="Activity_Reject">
        <dc:Bounds x="1060" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Approved_di" bpmnElement="Event_Approved">
        <dc:Bounds x="1222" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1217" y="185" width="47" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Rejected_di" bpmnElement="Event_Rejected">
        <dc:Bounds x="1222" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1219" y="345" width="43" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_Screen_di" bpmnElement="Flow_Start_Screen">
        <di:waypoint x="188" y="240" /><di:waypoint x="240" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Screen_Gw_di" bpmnElement="Flow_Screen_Gw">
        <di:waypoint x="340" y="240" /><di:waypoint x="395" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Gw_Auto_di" bpmnElement="Flow_Gw_Auto">
        <di:waypoint x="420" y="215" /><di:waypoint x="420" y="100" /><di:waypoint x="500" y="100" />
        <bpmndi:BPMNLabel><dc:Bounds x="426" y="106" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Gw_Review_di" bpmnElement="Flow_Gw_Review">
        <di:waypoint x="445" y="240" /><di:waypoint x="500" y="240" />
        <bpmndi:BPMNLabel><dc:Bounds x="458" y="222" width="14" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Auto_End_di" bpmnElement="Flow_Auto_End">
        <di:waypoint x="600" y="100" /><di:waypoint x="662" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Mark_Notify_di" bpmnElement="Flow_Mark_Notify">
        <di:waypoint x="600" y="240" /><di:waypoint x="650" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Notify_Review_di" bpmnElement="Flow_Notify_Review">
        <di:waypoint x="750" y="240" /><di:waypoint x="800" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Review_Gw_di" bpmnElement="Flow_Review_Gw">
        <di:waypoint x="900" y="240" /><di:waypoint x="955" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Timer_Escalate_di" bpmnElement="Flow_Timer_Escalate">
        <di:waypoint x="850" y="298" /><di:waypoint x="850" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Escalate_End_di" bpmnElement="Flow_Escalate_End">
        <di:waypoint x="900" y="400" /><di:waypoint x="962" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Gw_Approve_di" bpmnElement="Flow_Gw_Approve">
        <di:waypoint x="980" y="215" /><di:waypoint x="980" y="160" /><di:waypoint x="1060" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="986" y="166" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Gw_Reject_di" bpmnElement="Flow_Gw_Reject">
        <di:waypoint x="980" y="265" /><di:waypoint x="980" y="320" /><di:waypoint x="1060" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="988" y="298" width="14" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approve_End_di" bpmnElement="Flow_Approve_End">
        <di:waypoint x="1160" y="160" /><di:waypoint x="1222" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Reject_End_di" bpmnElement="Flow_Reject_End">
        <di:waypoint x="1160" y="320" /><di:waypoint x="1222" y="320" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
