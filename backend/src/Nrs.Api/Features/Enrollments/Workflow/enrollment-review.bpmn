<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_EnrollmentReview" targetNamespace="http://nrs.rop.gov.om/enrollment" exporter="Camunda Modeler" exporterVersion="5.48.0">
  <bpmn:message id="Message_CorrectionsSubmitted" name="corrections-submitted">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=enrollmentId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_Withdrawn" name="enrollment-withdrawn">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=enrollmentId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:process id="enrollment-review" name="Enrollment review" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Submitted">
      <bpmn:outgoing>Flow_Start_Screen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_Screen" name="Screen application">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="screen-application" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_Screen</bpmn:incoming>
      <bpmn:incoming>Flow_Msg_Screen</bpmn:incoming>
      <bpmn:outgoing>Flow_Screen_Gw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Auto" name="Clean renewal?" default="Flow_Gw_Review">
      <bpmn:incoming>Flow_Screen_Gw</bpmn:incoming>
      <bpmn:outgoing>Flow_Gw_Auto</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gw_Review</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_AutoApprove" name="Auto-approve">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="apply-approved" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gw_Auto</bpmn:incoming>
      <bpmn:outgoing>Flow_Auto_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_MarkReview" name="Queue for review">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="queue-for-review" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gw_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Mark_Notify</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_NotifyReviewers" name="Notify reviewers">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:taskHeaders>
          <zeebe:header key="kind" value="review-queued" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Mark_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_Review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_Review" name="Review application">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="=[reviewGroup]" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Notify_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_Gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Event_EscalationTimer" name="Review overdue" cancelActivity="false" attachedToRef="Activity_Review">
      <bpmn:outgoing>Flow_Timer_Escalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Escalation">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=escalationAfter</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="Activity_NotifySupervisor" name="Notify supervisor">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:taskHeaders>
          <zeebe:header key="kind" value="escalated" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Timer_Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_Escalate_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_Escalated" name="Escalation sent">
      <bpmn:incoming>Flow_Escalate_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_Outcome" name="Outcome?" default="Flow_Gw_Reject">
      <bpmn:incoming>Flow_Review_Gw</bpmn:incoming>
      <bpmn:outgoing>Flow_Gw_Approve</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gw_Corr</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gw_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_Approve" name="Approve application">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="apply-approved" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gw_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_Approve_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_Reject" name="Reject application">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="apply-rejected" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gw_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_Rejected" name="Rejected">
      <bpmn:incoming>Flow_Reject_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Activity_Provision" name="Provision registry">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="provision-registry" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Approve_End</bpmn:incoming>
      <bpmn:incoming>Flow_Auto_End</bpmn:incoming>
      <bpmn:outgoing>Flow_Provision_Print</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_PrintCard" name="Print card">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="operator" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Provision_Print</bpmn:incoming>
      <bpmn:outgoing>Flow_Print_Dispatch</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_Dispatch" name="Ready for collection">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="dispatch-card" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Print_Dispatch</bpmn:incoming>
      <bpmn:outgoing>Flow_Dispatch_Collect</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_Collect" name="Hand over card">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="operator" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Dispatch_Collect</bpmn:incoming>
      <bpmn:outgoing>Flow_Collect_Activate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_ActivateCard" name="Activate card">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="activate-card" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Collect_Activate</bpmn:incoming>
      <bpmn:outgoing>Flow_Activate_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_CardIssued" name="Card issued">
      <bpmn:incoming>Flow_Activate_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Activity_RequestCorrections" name="Request corrections">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="apply-corrections-requested" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gw_Corr</bpmn:incoming>
      <bpmn:outgoing>Flow_Corr_EventGw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:eventBasedGateway id="Gateway_Corrections" name="Resubmitted in time?">
      <bpmn:incoming>Flow_Corr_EventGw</bpmn:incoming>
      <bpmn:outgoing>Flow_Gw_Corr_Msg</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gw_Corr_Timer</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_CorrectionsSubmitted" name="Resubmitted">
      <bpmn:incoming>Flow_Gw_Corr_Msg</bpmn:incoming>
      <bpmn:outgoing>Flow_Msg_Screen</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Corr" messageRef="Message_CorrectionsSubmitted" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_CorrectionDeadline" name="Deadline passed">
      <bpmn:incoming>Flow_Gw_Corr_Timer</bpmn:incoming>
      <bpmn:outgoing>Flow_Timer_Abandon</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Correction">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=correctionDeadline</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Activity_Abandon" name="Close (abandoned)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="apply-abandoned" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Timer_Abandon</bpmn:incoming>
      <bpmn:outgoing>Flow_Abandon_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_Abandoned" name="Abandoned">
      <bpmn:incoming>Flow_Abandon_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="SubProcess_Withdraw" name="Withdrawal" triggeredByEvent="true">
      <bpmn:startEvent id="Event_WithdrawStart" name="Withdrawn">
        <bpmn:outgoing>Flow_Withdraw_Apply</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MED_Withdraw" messageRef="Message_Withdrawn" />
      </bpmn:startEvent>
      <bpmn:serviceTask id="Activity_ApplyWithdrawn" name="Apply withdrawal">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="apply-withdrawn" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_Withdraw_Apply</bpmn:incoming>
        <bpmn:outgoing>Flow_Withdraw_End</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="Event_Withdrawn" name="Withdrawn">
        <bpmn:incoming>Flow_Withdraw_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Withdraw_Apply" sourceRef="Event_WithdrawStart" targetRef="Activity_ApplyWithdrawn" />
      <bpmn:sequenceFlow id="Flow_Withdraw_End" sourceRef="Activity_ApplyWithdrawn" targetRef="Event_Withdrawn" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_Start_Screen" sourceRef="StartEvent_1" targetRef="Activity_Screen" />
    <bpmn:sequenceFlow id="Flow_Screen_Gw" sourceRef="Activity_Screen" targetRef="Gateway_Auto" />
    <bpmn:sequenceFlow id="Flow_Gw_Auto" name="yes" sourceRef="Gateway_Auto" targetRef="Activity_AutoApprove">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=autoApprove = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gw_Review" name="no" sourceRef="Gateway_Auto" targetRef="Activity_MarkReview" />
    <bpmn:sequenceFlow id="Flow_Auto_End" sourceRef="Activity_AutoApprove" targetRef="Activity_Provision" />
    <bpmn:sequenceFlow id="Flow_Mark_Notify" sourceRef="Activity_MarkReview" targetRef="Activity_NotifyReviewers" />
    <bpmn:sequenceFlow id="Flow_Notify_Review" sourceRef="Activity_NotifyReviewers" targetRef="Activity_Review" />
    <bpmn:sequenceFlow id="Flow_Review_Gw" sourceRef="Activity_Review" targetRef="Gateway_Outcome" />
    <bpmn:sequenceFlow id="Flow_Timer_Escalate" sourceRef="Event_EscalationTimer" targetRef="Activity_NotifySupervisor" />
    <bpmn:sequenceFlow id="Flow_Escalate_End" sourceRef="Activity_NotifySupervisor" targetRef="Event_Escalated" />
    <bpmn:sequenceFlow id="Flow_Gw_Approve" name="approve" sourceRef="Gateway_Outcome" targetRef="Activity_Approve">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=outcome = "approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gw_Corr" name="corrections" sourceRef="Gateway_Outcome" targetRef="Activity_RequestCorrections">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=outcome = "corrections"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gw_Reject" name="reject" sourceRef="Gateway_Outcome" targetRef="Activity_Reject" />
    <bpmn:sequenceFlow id="Flow_Reject_End" sourceRef="Activity_Reject" targetRef="Event_Rejected" />
    <bpmn:sequenceFlow id="Flow_Provision_Print" sourceRef="Activity_Provision" targetRef="Activity_PrintCard" />
    <bpmn:sequenceFlow id="Flow_Print_Dispatch" sourceRef="Activity_PrintCard" targetRef="Activity_Dispatch" />
    <bpmn:sequenceFlow id="Flow_Dispatch_Collect" sourceRef="Activity_Dispatch" targetRef="Activity_Collect" />
    <bpmn:sequenceFlow id="Flow_Collect_Activate" sourceRef="Activity_Collect" targetRef="Activity_ActivateCard" />
    <bpmn:sequenceFlow id="Flow_Activate_End" sourceRef="Activity_ActivateCard" targetRef="Event_CardIssued" />
    <bpmn:sequenceFlow id="Flow_Corr_EventGw" sourceRef="Activity_RequestCorrections" targetRef="Gateway_Corrections" />
    <bpmn:sequenceFlow id="Flow_Gw_Corr_Msg" sourceRef="Gateway_Corrections" targetRef="Event_CorrectionsSubmitted" />
    <bpmn:sequenceFlow id="Flow_Gw_Corr_Timer" sourceRef="Gateway_Corrections" targetRef="Event_CorrectionDeadline" />
    <bpmn:sequenceFlow id="Flow_Msg_Screen" sourceRef="Event_CorrectionsSubmitted" targetRef="Activity_Screen" />
    <bpmn:sequenceFlow id="Flow_Timer_Abandon" sourceRef="Event_CorrectionDeadline" targetRef="Activity_Abandon" />
    <bpmn:sequenceFlow id="Flow_Abandon_End" sourceRef="Activity_Abandon" targetRef="Event_Abandoned" />
    <bpmn:sequenceFlow id="Flow_Approve_End" sourceRef="Activity_Approve" targetRef="Activity_Provision" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="enrollment-review">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="146" y="435" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Screen_di" bpmnElement="Activity_Screen">
        <dc:Bounds x="240" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Auto_di" bpmnElement="Gateway_Auto" isMarkerVisible="true">
