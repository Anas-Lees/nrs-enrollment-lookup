      <bpmndi:BPMNShape id="Activity_Dispatch_di" bpmnElement="Activity_Dispatch">
        <dc:Bounds x="1590" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Collect_di" bpmnElement="Activity_Collect">
        <dc:Bounds x="1740" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ActivateCard_di" bpmnElement="Activity_ActivateCard">
        <dc:Bounds x="1890" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
