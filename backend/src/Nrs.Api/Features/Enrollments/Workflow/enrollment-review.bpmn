        <dc:Bounds x="1480" y="440" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Abandoned_di" bpmnElement="Event_Abandoned">
        <dc:Bounds x="1642" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1632" y="505" width="57" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubProcess_Withdraw_di" bpmnElement="SubProcess_Withdraw" isExpanded="true">
        <dc:Bounds x="340" y="470" width="420" height="160" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ApplyWithdrawn_di" bpmnElement="Activity_ApplyWithdrawn">
        <dc:Bounds x="500" y="510" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_WithdrawStart_di" bpmnElement="Event_WithdrawStart">
        <dc:Bounds x="412" y="532" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="406" y="575" width="52" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Withdrawn_di" bpmnElement="Event_Withdrawn">
        <dc:Bounds x="652" y="532" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="646" y="575" width="52" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Withdraw_Apply_di" bpmnElement="Flow_Withdraw_Apply">
        <di:waypoint x="448" y="550" />
        <di:waypoint x="500" y="550" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Withdraw_End_di" bpmnElement="Flow_Withdraw_End">
        <di:waypoint x="600" y="550" />
        <di:waypoint x="652" y="550" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Event_EscalationTimer_di" bpmnElement="Event_EscalationTimer">
        <dc:Bounds x="852" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="781" y="475" width="79" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Screen_di" bpmnElement="Flow_Start_Screen">
        <di:waypoint x="188" y="410" />
        <di:waypoint x="240" y="410" />
      </bpmndi:BPMNEdge>
