        <bpmndi:BPMNLabel>
          <dc:Bounds x="963" y="605" width="75" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AutoApprove_di" bpmnElement="Activity_AutoApprove">
        <dc:Bounds x="500" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Approve_di" bpmnElement="Activity_Approve">
        <dc:Bounds x="1100" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Provision_di" bpmnElement="Activity_Provision">
        <dc:Bounds x="1250" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
