{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "NRS API Overview",
  "tags": ["nrs", "otel"],
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "description": "Per-second rate of incoming HTTP requests to the API, by route, from OTel AspNetCore instrumentation.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request latency p95 (s)",
      "description": "95th percentile request duration, computed from the OTel duration histogram.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP responses by status code",
      "description": "Request rate split by HTTP status code.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "{{http_response_status_code}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total requests (last 15m)",
      "description": "Total HTTP requests handled by the API in the dashboard window.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_server_request_duration_seconds_count[15m]))",
          "legendFormat": "requests"
        }
      ]
    }
  ]
}
