{
  "realm": "nrs",
  "enabled": true,
  "displayName": "NRS Enrollment",
  "loginTheme": "nrs",
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "ar"],
  "defaultLocale": "en",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "quickLoginCheckMilliSeconds": 1000,
  "minimumQuickLoginWaitSeconds": 60,
  "roles": {
    "realm": [
      {
        "name": "operator",
        "description": "Enrollment counter operator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "nrs-spa",
      "name": "NRS Applicant Lookup SPA",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:4200/*", "https://*"],
      "webOrigins": ["http://localhost:4200", "+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-nrs-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "nrs-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "nrs-api",
      "name": "NRS Applicant Lookup API",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false
    }
  ],
  "users": [
    {
      "username": "operator1",
      "enabled": true,
      "emailVerified": true,
      "email": "operator1@nrs.example.om",
      "firstName": "Demo",
      "lastName": "Operator",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "operator1",
          "temporary": false
        }
      ],
      "realmRoles": ["operator"]
    }
  ]
}
